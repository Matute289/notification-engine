# syntax=docker/dockerfile:1.7
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/notification-outbox-relay ./cmd/outbox-relay

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/notification-outbox-relay /notification-outbox-relay
USER nonroot:nonroot
ENTRYPOINT ["/notification-outbox-relay"]
