# Copy to .env and tweak as needed.
LOG_LEVEL=info
HTTP_ADDR=:8080

# Postgres
POSTGRES_DSN=postgres://notif:notif@postgres:5432/notif?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://notif:notif@rabbitmq:5672/

# Provider selection: mock | real
PROVIDER_MODE=mock

# Per-channel rate limits (requests per hour, per user)
RATELIMIT_PUSH_PER_HOUR=20
RATELIMIT_SMS_PER_HOUR=5
RATELIMIT_EMAIL_PER_HOUR=10

# Per-app-key global QPS (0 disables)
APP_KEY_RATE_LIMIT=0
APP_KEY_RATE_WINDOW=1s

# HMAC clients (comma-separated key:secret pairs)
APP_CLIENTS=demo-app:demo-secret-please-change

# Worker channel (only used by cmd/worker)
WORKER_CHANNEL=push_ios
WORKER_CONCURRENCY=8

# Retry policy (max attempts before DLQ)
MAX_RETRIES=5
